{
  "manifest_version": 3,
  "name": "지식인 답변 생성기",
  "description": "네이버 지식인 질문을 분석하고 설득력 있는 답변을 생성합니다",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://kin.naver.com/*",
    "*://m.kin.naver.com/*",
    "*://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://kin.naver.com/*",
        "*://m.kin.naver.com/*"
      ],
      "js": ["extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
